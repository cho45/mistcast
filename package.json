{
  "name": "mistcast",
  "version": "1.0.0",
  "description": "Mistcastは、エアギャップ環境（ネットワークに接続されていないデバイス間）での音響通信を実現するための、堅牢で数学的に厳密なDSP（デジタル信号処理）コアライブラリです。",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc",
    "build": "vue-tsc && vite build",
    "build:wasm": "WASM_FLAVOR=both WASM_NO_OPT=1 node scripts/build-wasm.js",
    "build:wasm:perf": "WASM_FLAVOR=both WASM_NO_OPT=0 node scripts/build-wasm.js",
    "build:wasm:base": "WASM_FLAVOR=base WASM_NO_OPT=1 node scripts/build-wasm.js",
    "build:wasm:simd": "WASM_FLAVOR=simd WASM_NO_OPT=1 node scripts/build-wasm.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:components": "vitest run src/**/*.component.test.ts",
    "bench": "vitest run tests/performance.test.ts"
  },
  "keywords": [],
  "author": "cho45 <cho45@lowreal.net> (http://www.lowreal.net/)",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^28.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8"
  }
}
